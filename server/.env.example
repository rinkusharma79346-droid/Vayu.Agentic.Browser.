# VAYU MCP Relay Server — Environment Variables
# Copy this file to .env and customize

# Server port (Render sets this automatically)
PORT=10000

# Pairing code for Android browser authentication
# Must match the PAIRING_CODE in McpConfig.kt
PAIRING_CODE=vayu1234

# Optional API key for SSE client authentication
# Leave empty to disable API key auth
API_KEY=

# Maximum message size in bytes (default: 1MB)
MAX_MESSAGE_SIZE=1048576

# Timeout for relay requests to Android browser in ms (default: 60s)
RELAY_TIMEOUT=60000

# Heartbeat interval in ms (default: 30s)
HEARTBEAT_INTERVAL=30000

# Log level: debug | info | warn | error
LOG_LEVEL=info
